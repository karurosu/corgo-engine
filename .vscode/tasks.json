{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake: build",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"build-vs2022-sim",
				"--config",
				"Debug"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "ctest-core",
			"type": "shell",
			"command": "ctest",
			"args": [
				"--preset",
				"test-core-vs2022",
				"--output-on-failure"
			],
			"isBackground": false,
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "CMake: build (Release)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"build-vs2022-sim",
				"--config",
				"Release"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}